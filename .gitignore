# Виртуальное окружение Python — не загружаем его в репозиторий
venv/

# Папка с кэшированными bytecode-файлами Python — не нужна в репозитории
__pycache__/

# Кэш pytest — временные файлы тестов
.pytest_cache/

# Локальные JSON-файлы с реальными данными пользователей
*.json

# Файлы логов — генерируются при работе приложения
*.log

# Файлы IDE и редакторов — локальные настройки
.vscode/
.idea/
*.swp
*.swo
*~

# Файлы операционной системы — скрытые файлы Mac/Windows
.DS_Store
Thumbs.db
